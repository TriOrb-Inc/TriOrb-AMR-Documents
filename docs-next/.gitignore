_build/
_shots/
__pycache__/
*.pyc
.venv-docs2/

# rosdoc2 generated artifacts (regenerated by docs-next/docker/run_rosdoc2.sh).
_rosdoc2_out/
_rosdoc2_sources/
/packages/*
/packages/*/
# Tracked hand-edited files (not auto-generated output):
#   packages/index.md       — authoritative published-pkg list
#   packages/webapi.md      — hand-written package API page
#   packages/mqtt.md        — hand-written package API page
#   packages/visual_slam/*  — handwritten Visual SLAM page + API subpage
!/packages/index.md
!/packages/webapi.md
!/packages/mqtt.md
!/packages/visual_slam/
/packages/visual_slam/*
!/packages/visual_slam/index.md
!/packages/visual_slam/API.md

# interfaces/ holds rosdoc2 output for TriOrb-ROS2-Types packages
# (triorb_drive_interface etc). Same tracking policy as packages/.
/interfaces/*
/interfaces/*/
!/interfaces/index.md
*.mo

# B plan (Phase 4 pivot): rosdoc2-generated package docs are English-only.
# We no longer extract/translate msgids under packages/. Local .po files
# may still appear if an old `make gettext` is run, but they are not
# tracked and not expected to be consulted. Exceptions: the two
# hand-written pages packages/index.md and packages/visual_slam.md do
# need JA translations, so their PO files stay tracked.
/locale/ja/LC_MESSAGES/packages/*
/locale/ja/LC_MESSAGES/packages/*/
!/locale/ja/LC_MESSAGES/packages/index.po
!/locale/ja/LC_MESSAGES/packages/visual_slam/
/locale/ja/LC_MESSAGES/packages/visual_slam/*
!/locale/ja/LC_MESSAGES/packages/visual_slam/index.po
!/locale/ja/LC_MESSAGES/packages/visual_slam/API.po
